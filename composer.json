{
    "name": "natmalas/laravel-module-generator",
    "description": "Generate static module facades from attributed classes in Laravel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0",
        "nikic/php-parser": "^5.0",
        "illuminate/console": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nat\\ModuleGenerator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nat\\ModuleGenerator\\ModuleGeneratorServiceProvider"
            ]
        }
    }
}
